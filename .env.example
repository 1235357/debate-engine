# DebateEngine Environment Variables
# Get free API keys at:
#   - Google AI Studio: https://makersuite.google.com/app/apikey
#   - Groq: https://console.groq.com/keys
#   - NVIDIA NIM: https://build.nvidia.com/explore/discover

# Primary provider (stable mode) - Required
GOOGLE_API_KEY=your-google-ai-studio-api-key-here

# Backup provider (balanced mode) - Optional
GROQ_API_KEY=your-groq-api-key-here

# Third provider (diverse mode) - Optional
NVIDIA_API_KEY=your-nvidia-nim-api-key-here

# Provider mode: stable, balanced, or diverse
DEBATE_ENGINE_PROVIDER_MODE=stable

# Log level: DEBUG, INFO, WARNING, ERROR
DEBATE_ENGINE_LOG_LEVEL=INFO